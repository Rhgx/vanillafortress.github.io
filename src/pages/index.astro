---
import { Image } from "astro:assets";
import ExternalLink from "../components/external_link.astro";
import Layout from "../layouts/default.astro";
import soldier from "../assets/vftf/transparent/soldier.svg";
import socials from "../data/socials.yaml";
---

<Layout
  title="Vanilla Fortress"
  description="A community hub for vanilla TF2 servers.">

<div class="mid-align">

  <h1>Vanilla Fortress</h1>

  <p>UNDER CONSTRUCTION</p>

  <p>
    Vanilla Fortress is a community hub for finding and seeding vanilla TF2 servers
    reminiscent of the Quickplay era.
  </p>

  <p>Get notifications for sessions on our Discord server and Steam group!</p>

  <Image
    src={soldier}
    alt="Soldier"
    width={256}
    height={144}
    loading="eager"
    decoding="sync"
  />

  <h1>Get Fragging</h1>

  <div class="links">
    <ExternalLink href={socials.discord}>Discord Server</ExternalLink>
    <ExternalLink href={socials.steam}>Steam Group</ExternalLink>
  </div>

</div>

</Layout>
