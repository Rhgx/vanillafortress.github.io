---
import ExternalLink from "./external_link.astro";
import discordIcon from "../assets/icons/discord.svg?url";
import githubIcon from "../assets/icons/github.svg?url";
import steamIcon from "../assets/icons/steam.svg?url";
import socials from "../data/socials.yaml";

const socialLinks = [
  {
    href: socials.discord,
    label: "Discord",
    icon: discordIcon,
  },
  {
    href: socials.steam,
    label: "Steam",
    icon: steamIcon,
  },
  {
    href: socials.repo,
    label: "GitHub",
    icon: githubIcon,
  },
];

const currentYear = new Date().getFullYear();
---

<footer>

  <div class="mid-align">

    <p class="attribution">
      Created by <ExternalLink href={socials.spark}>_Spark</ExternalLink>,
      <ExternalLink href={socials.rocks}>Rocks</ExternalLink>, and
      <ExternalLink href={socials.tored}>Tored</ExternalLink>
      with support from the VFTF Discord community.
    </p>

    <nav class="link-icons" aria-label="Community links">
      {socialLinks.map((link) => (
        <ExternalLink
          href={link.href}
          aria-label={`${link.label} (opens in a new tab)`}
          data-tooltip={link.label}
        >
          <span
            class="link-icon"
            style={`--icon: url("${link.icon}")`}
            aria-hidden="true"
          ></span>
        </ExternalLink>
      ))}
    </nav>

    <p class="legal-notice">
      &copy; {currentYear} Vanilla Fortress. Not affiliated with Valve or the TF Team.
      Team Fortress 2 and related content are property of Valve Corporation.
    </p>

  </div>

</footer>
