---
import ExternalLink from "./external_link.astro";
import socials from "../data/socials.yaml";

const socialLinks = [
  {
    href: socials.discord,
    label: "Discord",
    icon: "/images/icons/discord.svg",
  },
  {
    href: socials.steam,
    label: "Steam",
    icon: "/images/icons/steam.svg",
  },
  {
    href: socials.repo,
    label: "GitHub",
    icon: "/images/icons/github.svg",
  },
];
---

<footer>

  <div class="mid-align">

    <p class="attribution">
      Website made by 
      <ExternalLink href={socials.spark}>_Spark,</ExternalLink>
      <ExternalLink href={socials.rocks}>Rocks,</ExternalLink>
      and 
      <ExternalLink href={socials.tored}>Tored</ExternalLink>
      with help from people in the VFTF Discord.
    </p>

    <nav class="link-icons" aria-label="Community links">
      {socialLinks.map((link) => (
        <ExternalLink
          href={link.href}
          aria-label={`${link.label} (opens in a new tab)`}
          data-tooltip={link.label}
        >
          <img
            src={link.icon}
            alt=""
            width="18"
            height="18"
            loading="lazy"
            decoding="async"
          />
        </ExternalLink>
      ))}
    </nav>

    <div class="legal-notice">
      <p>Vanilla Fortress is not in any way affiliated with Valve Corporation. or the TF Team.</p>
      <p>Team Fortress 2 and all related content are property of Valve Corporation.</p>
    </div>

  </div>

</footer>
